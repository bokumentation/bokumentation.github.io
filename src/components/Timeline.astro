---
import { Icon } from 'astro-icon/components'

interface Props {
  items: any[]
  showConnectors?: boolean
}

const { items, showConnectors = true } = Astro.props
---

<div class="relative">
  <!-- Timeline line -->
  {
    showConnectors && (
      <div class="absolute left-6 top-0 bottom-0 w-0.5 bg-border -translate-x-1/2"></div>
    )
  }
  
  <div class="space-y-8">
    {items.map((item: any) => {
      const data = item.data
      const startYear = data.startDate.getFullYear()
      const endYear = data.endDate ? data.endDate.getFullYear() : data.current ? 'Present' : 'Ongoing'
      
      return (
        <div class="relative flex items-start gap-4">
          <!-- Timeline dot -->
          {
            showConnectors && (
              <div class="relative z-10 flex-shrink-0">
                <div class="size-6 rounded-full bg-primary border-2 border-background flex items-center justify-center">
                  <Icon name="lucide:graduation-cap" class="size-3 text-primary-foreground" />
                </div>
              </div>
            )
          }
          
          <!-- Content -->
          <div class="flex-grow">
            <div class="bg-card border border-accent rounded-lg p-4">
              <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-2">
                <h3 class="text-lg font-medium">{data.institution}</h3>
                <div class="flex items-center gap-2">
                  <span class="text-sm text-muted-foreground bg-secondary px-2 py-1 rounded-md">
                    {startYear} – {endYear}
                  </span>
                  {
                    data.current && (
                      <span class="text-xs bg-green-500/10 text-green-600 dark:text-green-400 px-2 py-1 rounded-md">
                        Current
                      </span>
                    )
                  }
                </div>
              </div>
              
              <p class="text-foreground/80 mb-2">{data.degree}</p>
              
              {
                data.location && (
                  <div class="flex items-center gap-1 text-sm text-muted-foreground">
                    <Icon name="lucide:map-pin" class="size-3" />
                    {data.location}
                  </div>
                )
              }
            </div>
          </div>
        </div>
      )
    })}
  </div>
</div>