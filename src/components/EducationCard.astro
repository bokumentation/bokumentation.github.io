---
import { Badge } from '@/components/ui/badge'
import { formatDate } from '@/lib/utils'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'
import type { CollectionEntry } from 'astro:content'

interface Props {
  education: CollectionEntry<'education'>
  showDetails?: boolean
}

const { education, showDetails = true } = Astro.props
const { institution, degree, field, startDate, endDate, location, gpa, description, achievements, courses, logo, current } = education.data
---

<div
  class="shadow-card rounded-lg p-6 transition-all duration-200 hover:shadow-card-hover"
  id={`education-${education.id}`}
>
  <div class="flex flex-col gap-5">
    <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4">
      <div class="flex items-start gap-4">
        {logo && (
          <div class="shrink-0">
            <Image
              src={logo}
              alt={`${institution} logo`}
              width={48}
              height={48}
              class="size-12 rounded-lg object-cover shadow-border"
            />
          </div>
        )}
        
        <div class="flex-grow">
          <h3 class="text-lg font-semibold tracking-title">
            {institution}
          </h3>
          <div class="flex flex-col sm:flex-row sm:flex-wrap sm:items-center gap-2 mt-1">
            <p class="text-muted-foreground text-sm">
              {degree}
              {field && ` - ${field}`}
            </p>
            {location && (
              <span class="text-muted-foreground flex items-center gap-1 text-xs">
                <Icon name="lucide:map-pin" class="size-3" />
                {location}
              </span>
            )}
          </div>
        </div>
      </div>
      
      <div class="shrink-0 mt-2 sm:mt-0">
        <p class="text-muted-foreground text-xs">
          <span class="flex items-center gap-1">
            <Icon name="lucide:calendar" class="size-3" />
            <span class="whitespace-nowrap">
              {formatDate(startDate)}
              {endDate ? ` - ${formatDate(endDate)}` : current ? ' - Present' : ''}
            </span>
          </span>
        </p>
      </div>
    </div>
    
    {gpa && (
      <div class="flex flex-wrap gap-2">
        <Badge variant="secondary" className="gap-1">
          <Icon name="lucide:award" class="size-3" />
          GPA: {gpa}
        </Badge>
      </div>
    )}
    
    {description && showDetails && (
      <p class="text-muted-foreground text-sm leading-relaxed">
        {description}
      </p>
    )}
    
    {achievements && achievements.length > 0 && showDetails && (
      <div class="space-y-2">
        <h4 class="text-sm font-medium">Achievements</h4>
        <ul class="space-y-1 text-sm text-muted-foreground">
          {achievements.map((achievement: string) => (
            <li class="flex items-start gap-2">
              <Icon name="lucide:check-circle" class="size-3 mt-0.5" />
              <span>{achievement}</span>
            </li>
          ))}
        </ul>
      </div>
    )}
    
    {courses && courses.length > 0 && showDetails && (
      <div class="space-y-2">
        <h4 class="text-sm font-medium">Relevant Courses</h4>
        <div class="flex flex-wrap gap-2">
          {courses.map((course: string) => (
            <Badge variant="outline">
              {course}
            </Badge>
          ))}
        </div>
      </div>
    )}
    
    {current && (
      <div class="flex justify-end">
        <Badge variant="default" className="gap-1">
          <Icon name="lucide:clock" class="size-3" />
          Current
        </Badge>
      </div>
    )}
  </div>
</div>