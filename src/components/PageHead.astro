---
import { SITE } from '@/consts'

interface Props {
  title?: string
  description?: string
  noindex?: boolean
  robots?: string
  image?: string
  type?: 'website' | 'article'
  publishedTime?: string
  modifiedTime?: string
  authors?: string[]
  keywords?: string[]
}

const {
  title = SITE.title,
  description = SITE.description,
  noindex = false,
  robots = 'index, follow',
  image,
  type = 'website',
  publishedTime,
  modifiedTime,
  authors,
  keywords = [
    'programming',
    'technology',
    'software engineering',
    'documentation',
    'tutorial',
  ],
} = Astro.props

const siteHref = SITE.href || Astro.site

// Use provided image or default to static placeholder
const ogImage = image
  ? new URL(image, Astro.site).href
  : new URL('/static/1200x630.png', Astro.site).href

const pathname =
  Astro.url.pathname.endsWith('/') && Astro.url.pathname.length > 1
    ? Astro.url.pathname.slice(0, -1)
    : Astro.url.pathname
const canonicalUrl = new URL(pathname, siteHref).href

// Combine with site keywords
const allKeywords = [
  ...keywords,
  'programming',
  'technology',
  'ibe ibrahim',
].join(', ')
---

<title>{`${title} | ${SITE.title}`}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />
<meta name="robots" content={noindex ? 'noindex, nofollow' : robots} />
<meta name="googlebot" content="index, follow" />
<meta name="bingbot" content="index, follow" />
<meta name="referrer" content="origin-when-cross-origin" />

<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:alt" content={title} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:type" content={type} />
<meta property="og:locale" content={SITE.locale} />
<meta property="og:site_name" content={SITE.title} />
<meta property="og:url" content={Astro.url} />

{
  publishedTime && (
    <meta property="article:published_time" content={publishedTime} />
  )
}
{
  modifiedTime && (
    <meta property="article:modified_time" content={modifiedTime} />
  )
}
{
  type === 'article' &&
    authors &&
    authors.map((author) => <meta property="article:author" content={author} />)
}
{type === 'article' && <meta property="article:section" content="Technology" />}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content={title} />
<meta name="twitter:creator" content="@bokumentation" />
<meta name="twitter:site" content="@bokumentation" />

<meta name="author" content={SITE.author} />
<meta name="keywords" content={allKeywords} />
<meta name="language" content={SITE.locale.split('-')[0]} />
<meta name="revisit-after" content="7 days" />
<meta name="rating" content="general" />
<meta name="audience" content="developers, programmers, tech enthusiasts" />

<script
  is:inline
  type="application/ld+json"
  set:html={`{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": "${canonicalUrl}",
      "url": "${canonicalUrl}",
      "name": "${SITE.title}",
      "description": "${description}",
      "publisher": {
        "@id": "${canonicalUrl}#organization"
      },
      "potentialAction": {
        "@type": "SearchAction",
        "target": "${canonicalUrl}?q={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@type": "Organization",
      "@id": "${canonicalUrl}#organization",
      "name": "${SITE.title}",
      "url": "${canonicalUrl}",
      "logo": {
        "@type": "ImageObject",
        "url": "${SITE.href}/static/logo.png",
        "width": 600,
        "height": 60
      },
      "sameAs": [
        "https://github.com/bumentation",
        "https://youtube.com/@bumentation",
        "https://instagram.com/bokumentation"
      ]
    }
  ]
}`}
/>

{
  type === 'article' && (
    <script
      is:inline
      type="application/ld+json"
      set:html={`{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "${canonicalUrl}"
  },
  "headline": "${title}",
  "description": "${description}",
  "image": {
    "@type": "ImageObject",
    "url": "${ogImage}"
  },
  "datePublished": "${publishedTime || new Date().toISOString()}",
  "dateModified": "${modifiedTime || new Date().toISOString()}",
  "author": [
    {
      "@type": "Person",
      "@id": "${SITE.href}#author",
      "name": "${authors?.[0] || SITE.author}",
      "url": "${SITE.href}#author"
    }
  ],
  "publisher": {
    "@type": "Organization",
    "@id": "${canonicalUrl}#organization",
    "name": "${SITE.title}",
    "logo": {
      "@type": "ImageObject",
      "url": "${SITE.href}/static/logo.png",
      "width": 600,
      "height": 60
    }
  },
  "keywords": "${allKeywords}",
  "articleSection": "Technology",
  "inLanguage": "${SITE.locale}"
}`}
    />
  )
}

<script
  is:inline
  type="application/ld+json"
  set:html={`{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "${SITE.href}"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "${title.replace(' | ' + SITE.title, '')}"
    }
  ]
}`}
/>
