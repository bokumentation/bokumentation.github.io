---
import Link from '@/components/Link.astro'
import ThemeToggle from '@/components/ThemeToggle.astro'
import MobileMenu from '@/components/ui/mobile-menu'
import { NAV_LINKS, SITE } from '@/consts'
---

<header class="z-50 bg-background shadow-border">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-4">
    <Link href="/" class="text-xl font-semibold tracking-tight">
      {SITE.title}
    </Link>

    <nav class="hidden items-center gap-8 text-sm sm:flex">
      {NAV_LINKS.map((item) => (
        <Link
          href={item.href}
          class="text-foreground/70 hover:text-foreground font-medium transition-colors"
        >
          {item.label}
        </Link>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <ThemeToggle />
      <MobileMenu client:visible />
    </div>
  </div>
</header>