---
import AuthorCard from '@/components/AuthorCard.astro'
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import PageHead from '@/components/PageHead.astro'
import Layout from '@/layouts/Layout.astro'
import { getAllAuthors } from '@/lib/data-utils'

const authors = await getAllAuthors()
---

<Layout class="max-w-3xl px-4 sm:px-6">
  <PageHead slot="head" title="About" />
  <Breadcrumbs items={[{ label: 'About', icon: 'lucide:info' }]} />

  <section class="mb-8">
    <h1
      class="tracking-title mb-4 font-[family-name:var(--font-heading)] text-2xl font-bold"
    >
      Meet the Author
    </h1>
    <div class="mb-4">
      {
        authors.length > 0 ? (
          <ul class="flex flex-col gap-4">
            {authors.map((author) => (
              <li>
                <AuthorCard author={author} />
              </li>
            ))}
          </ul>
        ) : (
          <p class="text-muted-foreground text-center">No authors found.</p>
        )
      }
    </div>
    <div class="prose prose-sm sm:prose-base">
      <p class="mt-0">The Original Name</p>
    </div>
  </section>

  <section class="mb-8">
    <h2
      class="tracking-title mb-4 font-[family-name:var(--font-heading)] text-2xl font-bold"
    >
      Behind the Scene
    </h2>
    <div class="prose prose-sm sm:prose-base mb-4">
      <p class="mt-0">
        This website is built with Astro, a modern static site generator that
        delivers fast, content-focused websites. The project leverages Astro's
        islands architecture for optimal performance and uses Tailwind CSS v4
        for styling.
      </p>
      <p>
        The site features a content collection system for managing blog posts,
        projects, authors, and now education history. All content is written in
        Markdown/MDX and automatically optimized for production builds.
      </p>
      <p>Key technologies used in this project include:</p>
      <ul>
        <li>
          <strong>Astro</strong> - Static site generation and component framework
        </li>
        <li><strong>Tailwind CSS v4</strong> - Utility-first CSS framework</li>
        <li><strong>TypeScript</strong> - Type-safe JavaScript development</li>
        <li><strong>MDX</strong> - Markdown with JSX components</li>
        <li><strong>React components</strong> - Interactive UI elements</li>
        <li>
          <strong>Lucide Icons</strong> - Beautiful, consistent iconography
        </li>
      </ul>
      <p>
        The site is deployed on GitHub Pages and automatically builds with every
        push to the main branch, ensuring the latest content is always available
        to visitors.
      </p>
    </div>
  </section>
</Layout>
