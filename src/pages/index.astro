---
import BlogCard from '@/components/BlogCard.astro'
import PageHead from '@/components/PageHead.astro'
import { SITE, SOCIAL_LINKS } from '@/consts'
import Layout from '@/layouts/Layout.astro'
import { getRecentPosts } from '@/lib/data-utils'
import SocialIcons from '@/components/SocialIcons.astro'

const blog = await getRecentPosts(SITE.featuredPostCount)
---

<Layout class="">
  <PageHead slot="head" title="Home" />

  <div class="flex flex-col gap-16 py-8 sm:gap-24 sm:py-12">
    <!-- Hero Section -->
    <section class="mx-auto flex max-w-3xl flex-col items-center text-center">
      <div
        class="bg-secondary text-secondary-foreground shadow-border mb-6 inline-flex items-center rounded-full px-3 py-1 text-xs font-medium"
      >
        Academic Blog
      </div>

      <h1
        class="tracking-title mb-6 text-2xl leading-[1.1] font-semibold sm:text-3xl"
      >
        Documentation, refined through research and practice
      </h1>

      <p class="text-muted-foreground mb-8 max-w-2xl text-sm leading-relaxed">
        Low-level system programming, embedded development, and cinematography.
        Exploring the intersection of hardware and software through technical
        documentation.
      </p>

      <div class="flex items-center gap-4">
        <a
          href="/blog"
          class="bg-foreground text-background hover:bg-foreground/90 shadow-border inline-flex items-center justify-center rounded-md px-5 py-2.5 text-sm font-medium transition-colors"
        >
          Read the blog
        </a>
        <a
          href="/about"
          class="hover:bg-secondary shadow-border inline-flex items-center justify-center rounded-md px-5 py-2.5 text-sm font-medium transition-colors"
        >
          About me
        </a>
      </div>

      <div class="mt-8 flex items-center gap-4">
        <SocialIcons links={SOCIAL_LINKS} />
      </div>
    </section>

    <!-- Blog Section -->
    <section class="mx-auto flex w-full max-w-3xl flex-col gap-8">
      <div class="flex items-center justify-between">
        <div>
          <h2 class="tracking-heading text-lg font-semibold">Latest posts</h2>
          <p class="text-muted-foreground mt-1 text-sm">
            Recent articles and tutorials
          </p>
        </div>
        <a
          href="/blog"
          class="text-muted-foreground hover:text-foreground text-sm transition-colors"
        >
          View all &rarr;
        </a>
      </div>

      <ul class="grid grid-cols-2 gap-3 max-[480px]:grid-cols-1">
        {
          blog.map((post, i) => (
            <li>
              <BlogCard entry={post} priority={i === 0} />
            </li>
          ))
        }
      </ul>
    </section>
  </div>
</Layout>
