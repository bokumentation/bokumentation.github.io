#!/bin/sh

# Check if .env contains real values (not placeholders)
if [ -f ".env" ]; then
  # Check for common patterns that indicate real credentials
  if grep -qE "(api[_-]?key|secret|password|token)\s*=\s*['\"][^'\"]+['\"]" .env 2>/dev/null; then
    echo "❌ ERROR: .env file appears to contain real credentials."
    echo "Please ensure .env is in .gitignore and never commit sensitive data."
    exit 1
  fi
fi

# Check for common sensitive file patterns in staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null)

# Block .env files from being committed (but allow .env.example, .env.sample, etc.)
if echo "$STAGED_FILES" | grep -q '^\.env$'; then
  echo "❌ ERROR: Attempting to commit .env file(s)."
  echo "Environment files should not be committed to version control."
  exit 1
fi

echo "✅ Pre-commit checks passed."