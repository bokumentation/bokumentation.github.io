* text=auto

# Source files — force LF on all platforms
*.js    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.astro text eol=lf
*.css   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.mdx   text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.xml   text eol=lf
*.svg   text eol=lf

# Binary files — never attempt text diff/merge
*.png   binary
*.jpg   binary
*.jpeg  binary
*.webp  binary
*.woff2 binary
*.ico   binary
*.webmanifest binary

# Exclude from downloaded archives
.gitattributes export-ignore
.gitignore     export-ignore