# Environment Variables for Bokumentation
# Copy this file to .env and fill in the values

# Public Contact Email (used for mailto links)
# This email will be publicly visible in the contact links
PUBLIC_CONTACT_EMAIL=your-email@example.com

# Social Media URLs
PUBLIC_YOUTUBE_URL=https://youtube.com/@bokumentation
PUBLIC_GITHUB_URL=https://github.com/bokumentation
PUBLIC_INSTAGRAM_URL=https://instagram.com/bokumentation
PUBLIC_LINKEDIN_URL=https://linkedin.com/in/bokumentation
PUBLIC_TWITTER_URL=https://twitter.com/bokumentation
PUBLIC_WEBSITE_URL=https://bokumentation.site

# Note: In Astro, environment variables prefixed with PUBLIC_ are exposed to the client-side code.
# Never put sensitive information (like API keys, passwords) in PUBLIC_ variables.
# For server-side only variables, use unprefixed variables (without PUBLIC_).

# Example server-side only variables (not exposed to client):
# DATABASE_URL=postgresql://user:password@localhost:5432/db
# API_SECRET_KEY=your-secret-key-here